<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="head.additional">
            <block template="PayU_PaymentGateway::credit_widget/head_script.phtml" before="-">
                <arguments>
                    <argument name="configKey" xsi:type="string">enable_for_cart</argument>
                    <argument name="creditWidgetViewModel" xsi:type="object">PayU\PaymentGateway\ViewModel\CreditWidgetViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
        <referenceBlock name="checkout.cart.totals">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="block-totals" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="payu-credit-widget-cart" xsi:type="array">
                                    <item name="component" xsi:type="string">PayU_PaymentGateway/js/view/cart/credit_widget_cart</item>
                                    <item name="sortOrder" xsi:type="number">1000</item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
