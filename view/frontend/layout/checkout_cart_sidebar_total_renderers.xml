<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <referenceContainer name="head.additional">
        <block template="PayU_PaymentGateway::credit_widget/head_script.phtml" before="-">
            <arguments>
                <argument name="configKey" xsi:type="string">enable_for_minicart</argument>
                <argument name="creditWidgetViewModel" xsi:type="object">PayU\PaymentGateway\ViewModel\CreditWidgetViewModel</argument>
            </arguments>
        </block>
        <block template="PayU_PaymentGateway::credit_widget/minicart_config.phtml" before="-">
            <arguments>
                <argument name="creditWidgetViewModel" xsi:type="object">PayU\PaymentGateway\ViewModel\CreditWidgetViewModel</argument>
            </arguments>
        </block>
    </referenceContainer>
    <body>
        <referenceBlock name="minicart">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="minicart_content" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="subtotal.container" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="subtotal" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="payu-credit-widget-minicart" xsi:type="array">
                                                    <item name="component" xsi:type="string">PayU_PaymentGateway/js/view/minicart/credit_widget</item>
                                                    <item name="sortOrder" xsi:type="number">20</item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
