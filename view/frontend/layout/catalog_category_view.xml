<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="head.additional">
            <block template="PayU_PaymentGateway::credit_widget/head_script.phtml"
                    before="-">
                <arguments>
                    <argument name="creditWidgetViewModel" xsi:type="object">PayU\PaymentGateway\ViewModel\CreditWidgetViewModel</argument>
                    <argument name="configKey" xsi:type="string">enable_for_catalog</argument>
                </arguments>
            </block>
        </referenceContainer>

        <block class="Magento\Catalog\Block\Product\AbstractProduct"
                name="payu.credit.widget.simulation"
                template="PayU_PaymentGateway::product/credit_widget.phtml"
                ifconfig="payment/payu_credit_widget/enable_for_catalog"
        >
            <arguments>
                <argument name="creditWidgetViewModel" xsi:type="object">PayU\PaymentGateway\ViewModel\CreditWidgetViewModel</argument>
            </arguments>
        </block>
    </body>
</page>