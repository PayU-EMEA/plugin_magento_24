                        <frontend_class>validate-number</frontend_class>
                        <config_path>payment/payu_gateway_installments/sort_order</config_path>
                    </field>
                </group>
                <group id="payu_gateway_klarna" translate="label" type="text" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>PayU - Klarna</label>
                    <field id="active" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Enable plugin?</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
