<?xml version="1.0" encoding="UTF-8"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="connect-src">
            <values>
                <value id="payu" type="host">secure.payu.com</value>
                <value id="payu-sandbox" type="host">merch-prod.snd.payu.com</value>
                <value id="payu-static" type="host">static.payu.com</value>
                <value id="payu-credit-widget" type="host">credit-widget-config.payu.com/</value>
                <value id="google-pay-connect" type="host">pay.google.com</value>
                <value id="google-api-connect" type="host">*.googleapis.com</value>
            </values>
        </policy>
        <policy id="script-src">
            <values>
                <value id="payu" type="host">secure.payu.com</value>
                <value id="payu-sandbox" type="host">secure.snd.payu.com</value>
                <value id="payu-static" type="host">static.payu.com</value>
                <value id="payu-credit-widget" type="host">credit-widget-config.payu.com/</value>
                <value id="google-pay-script" type="host">*.google.com</value>
                <value id="google-pay-pay" type="host">pay.google.com</value>
                <value id="google-gstatic" type="host">*.gstatic.com</value>
                <value id="google-apis" type="host">*.googleapis.com</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="payu-static" type="host">static.payu.com</value>
                <value id="payu-credit-widget" type="host">credit-widget-config.payu.com/</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="payu" type="host">secure.payu.com</value>
                <value id="payu-sandbox" type="host">merch-prod.snd.payu.com</value>
                <value id="payu-static" type="host">static.payu.com</value>
                <value id="payu-credit-widget" type="host">credit-widget-config.payu.com/</value>
                <value id="google-pay-frame" type="host">pay.google.com</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>
                <value id="payu-static-font" type="host">static.payu.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
